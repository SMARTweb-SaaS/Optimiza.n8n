        "jsCode": "const tenant = $('Normalizar').first().json.tenant;\nconst e = $input.all().map(i=>i.json).find(r=>r.tenant===tenant) || {};\nconst norm = $('Normalizar').first().json;\n// Construir un body compatible con la estructura que espera el Agente\nconst bodyCompatible = {\n  data: {\n    key: {\n      remoteJid: norm.remoteJid,\n      fromMe: false\n    },\n    message: { conversation: norm.texto },\n    messageType: 'conversation'\n  }\n};\nreturn [{ json: {\n  body:              bodyCompatible,\n  tenant:            e.tenant,\n  empresaNombre:     e.nombre,\n  email:             e.email,\n  calEventTypeId:    String(e.cal_event_type_id || ''),\n  calApiKey:         e.cal_api_key,\n  evolutionInstance: e.evolution_instance,\n  evolutionUrl:      e.evolution_url,\n  origen:            'formulario'\n} }];"
