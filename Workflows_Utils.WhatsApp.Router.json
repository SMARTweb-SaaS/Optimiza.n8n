      "parameters": {
        "jsCode": "// Detectar origen por estructura del payload\nconst body = $json.body || $json;\nconst desdeEvolution = !!(body?.data?.key?.remoteJid);\n\nlet remoteJid, texto, tenant;\n\nif (desdeEvolution) {\n  remoteJid = body.data.key.remoteJid;\n  texto      = body.data.message?.conversation || '';\n  tenant     = null;\n} else {\n  // Formulario web: normalizar teléfono → formato WhatsApp\n  const tel = (body.telefono || body.phone || body.remoteJid || '')\n    .toString().replace(/\\D/g, '');\n  remoteJid = tel.includes('@') ? tel : tel + '@s.whatsapp.net';\n  texto      = body.mensaje || body.message || body.consulta || '';\n  tenant     = body.tenant || null;\n}\n\nreturn [{ json: {\n  remoteJid,\n  texto,\n  tenant,\n  origen: desdeEvolution ? 'whatsapp' : 'formulario',\n  bodyRaw: body\n}}];"
      },
